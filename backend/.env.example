# Flask Configuration Template
# 
# Instructions:
# 1. Copy this file and rename it to '.env'
# 2. Replace all placeholder values with your actual credentials
# 3. Never commit the actual .env file to version control

# Flask Settings
FLASK_APP=app.py
FLASK_ENV=development
PORT=5000

# Google Cloud / Firebase Credentials
# Option 1: Path to service account key file (recommended for local development)
GOOGLE_APPLICATION_CREDENTIALS=./serviceAccountKey.json

# Option 2: JSON content directly (useful for deployment platforms like Heroku)
# GOOGLE_APPLICATION_CREDENTIALS_JSON='{"type":"service_account","project_id":"your-project",...}'

# CORS Settings (comma-separated list of allowed origins)
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:8080

# Security (add these for production)
# SECRET_KEY=your-secret-key-here-generate-a-random-string
# SESSION_COOKIE_SECURE=True
# SESSION_COOKIE_HTTPONLY=True